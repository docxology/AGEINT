# AGEINT generated outputs — published with the release so the rendered
# manuscript, figures, PDF, web, and audit reports are browsable on GitHub.
# Negation overrides the parent core.excludesFile, which ignores output/.
!output/
!output/**
# ...but keep transient build state out of the repo:
output/logs/
output/.checkpoints/
output/.pipeline/
output/llm/
output/simulations/
output/tex/
.coverage
coverage*.json
htmlcov/
.pytest_cache/
.benchmarks/
.mypy_cache/
.ruff_cache/
__pycache__/
*.pyc
*.egg-info/
.venv/
tmp/
.DS_Store
