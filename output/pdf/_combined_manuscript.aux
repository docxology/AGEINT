\@writefile{lof}{\contentsline {figure}{\numberline {49}{\ignorespaces This diagram presents a confidence ladder that ties an imagery interpretation's defensibility to resolution fit, temporal fit, corroboration, and an explicit sensitive-site boundary that separates map reading from targeting or attribution. In the open source intelligence osint / geoint and imagery intelligence section, it lets readers compare Imagery observation and metadata, Sensitive-site minimization boundary, Low confidence: caveat heavily, and Moderate confidence so the visual functions as a traceable course aid rather than an unscoped assertion.}}{343}{figure.caption.51}\protected@file@percent }
\newlabel{fig:geoint-imagery-confidence-ladder}{{49}{343}{This diagram presents a confidence ladder that ties an imagery interpretation's defensibility to resolution fit, temporal fit, corroboration, and an explicit sensitive-site boundary that separates map reading from targeting or attribution. In the open source intelligence osint / geoint and imagery intelligence section, it lets readers compare Imagery observation and metadata, Sensitive-site minimization boundary, Low confidence: caveat heavily, and Moderate confidence so the visual functions as a traceable course aid rather than an unscoped assertion}{figure.caption.51}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {50}{\ignorespaces Public-domain USGS EROS declassified imagery of the Forbidden City as a local historical image for GEOINT source-provenance discussion. Its reader value is to make U.S. Geological Survey provenance, 1966 approx. collection context, public-domain status, and analytic reuse boundary visible at a glance, with the open source intelligence osint / geoint and imagery intelligence section as the source section and defensive review as the boundary.}}{344}{figure.caption.52}\protected@file@percent }
\newlabel{fig:historical-forbidden-city}{{50}{344}{Public-domain USGS EROS declassified imagery of the Forbidden City as a local historical image for GEOINT source-provenance discussion. Its reader value is to make U.S. Geological Survey provenance, 1966 approx. collection context, public-domain status, and analytic reuse boundary visible at a glance, with the open source intelligence osint / geoint and imagery intelligence section as the source section and defensive review as the boundary}{figure.caption.52}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {51}{\ignorespaces Public-domain USGS EROS KH-9 image used as a historical example of declassified remote-sensing material with explicit provenance. It is anchored to the open source intelligence osint / geoint and imagery intelligence section; use it to inspect U.S. Geological Survey provenance, 1982-07-22 collection context, public-domain status, and analytic reuse boundary while preserving the distinction between curriculum structure, evidence boundary, and accountable practice.}}{345}{figure.caption.53}\protected@file@percent }
\newlabel{fig:historical-missouri-river-kh9}{{51}{345}{Public-domain USGS EROS KH-9 image used as a historical example of declassified remote-sensing material with explicit provenance. It is anchored to the open source intelligence osint / geoint and imagery intelligence section; use it to inspect U.S. Geological Survey provenance, 1982-07-22 collection context, public-domain status, and analytic reuse boundary while preserving the distinction between curriculum structure, evidence boundary, and accountable practice}{figure.caption.53}{}}
