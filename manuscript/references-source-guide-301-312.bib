@misc{ageint309,
  title = {STIX Version 2.1},
  author = {SIST Guide Reference 309},
  year = {2026},
  url = {https://docs.oasis-open.org/cti/stix/v2.1/stix-v2.1.html},
  note = {An OASIS standard specification defining STIX (Structured Threat Information Expression), a language for exchanging cyber threat intelligence in a standardized, machine-readable form. It establishes a graph-based model with STIX Domain Objects, Cyber-observable Objects, and Relationship Objects, plus meta objects, bundles, and a patterning language for detection},
}

@misc{ageint310,
  title = {TAXII Version 2.1},
  author = {SIST Guide Reference 310},
  year = {2026},
  url = {https://docs.oasis-open.org/cti/taxii/v2.1/taxii-v2.1.html},
  note = {The OASIS Standard specification for TAXII (Trusted Automated Exchange of Intelligence Information) Version 2.1, published in 2021 by the OASIS Cyber Threat Intelligence Technical Committee. It defines a RESTful, HTTPS-based API protocol for sharing cyber threat intelligence between organizations, supporting two communication models: Collections (request-response) and Channels (publish-subscribe)},
}

@misc{ageint311,
  title = {Countering Information Threats},
  author = {SIST Guide Reference 311},
  year = {2026},
  url = {https://www.nato.int/cps/en/natohq/topics_219728.htm},
  note = {An official NATO topic page describing the Alliance's approach to countering information threats, defined as intentional, manipulative, and coordinated activities by state and non-state actors including disinformation and propaganda. It explains why such threats matter for democratic processes and institutional trust, and outlines a four-part framework of understanding, preventing, containing, and recovering},
}

